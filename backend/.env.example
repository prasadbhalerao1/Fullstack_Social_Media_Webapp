NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/socialmedia
JWT_SECRET=your_jwt_secret_here
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,https://runtime-dev.vercel.app

# SMTP/Email Configurations (e.g. Gmail App Passwords or Brevo SMTP Relay)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM="RUNTIME Dev Social" <your_email@gmail.com>